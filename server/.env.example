# ===================================================
# Sevanto Server Environment (example — copy to .env)
# ===================================================

# ---- Runtime ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---- Database ----
DATABASE_URL=postgresql://sevanto:sevanto@localhost:5432/sevanto?schema=public

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- JWT ----
JWT_ACCESS_SECRET=replace-with-strong-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-strong-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- Mail (SMTP) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASS=
MAIL_FROM="Sevanto <no-reply@sevanto.app>"
MAIL_SECURE=false

# ---- App URLs (for email links) ----
APP_BASE_URL_CLIENT=http://localhost:3001
APP_BASE_URL_WORKER=http://localhost:3002
APP_BASE_URL_ADMIN=http://localhost:3003

# ---- CORS ----
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003

# ---- Rate limiting ----
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ---- Seed admin ----
ADMIN_EMAIL=admin@sevanto.app
ADMIN_PASSWORD=ChangeMe123!
ADMIN_FULL_NAME=Sevanto Admin

# ---- Storage (S3-compatible, used in later phases) ----
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_PUBLIC_URL=