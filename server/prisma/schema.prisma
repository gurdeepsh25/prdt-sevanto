// Sevanto Prisma schema
//   Phase 1 — Authentication (init)
//   Phase 2 — User Management (User fields + UserAddress)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// Enums
// =====================================================

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

// =====================================================
// Users
// =====================================================

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique @db.Citext
  passwordHash   String    @map("password_hash")
  role           Role
  fullName       String    @map("full_name")
  phone          String?
  avatarUrl      String?   @map("avatar_url")
  isActive       Boolean   @default(true) @map("is_active")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(3)

  refreshTokens        RefreshToken[]
  passwordResets       PasswordReset[]
  emailVerifications   EmailVerification[]
  addresses            UserAddress[]

  @@index([role])
  @@map("users")
}

// =====================================================
// User addresses (Phase 2)
// =====================================================

model UserAddress {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  label      String?  // e.g. "Home", "Office"
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String   @map("postal_code")
  country    String   @default("IN")
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

// =====================================================
// Refresh tokens (hashed at rest)
// =====================================================

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  familyId  String    @map("family_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// =====================================================
// Password reset tokens (single-use)
// =====================================================

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// =====================================================
// Email verification tokens (single-use)
// =====================================================

model EmailVerification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}