// Sevanto Prisma schema
//   Phase 1 — Authentication (init)
//   Phase 2 — User Management (User fields + UserAddress)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================================
// Enums
// =====================================================

enum Role {
  CUSTOMER
  WORKER
  ADMIN
}

// =====================================================
// Users
// =====================================================

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique @db.Citext
  passwordHash    String    @map("password_hash")
  role            Role
  fullName        String    @map("full_name")
  phone           String?
  avatarUrl       String?   @map("avatar_url")
  isActive        Boolean   @default(true) @map("is_active")
  isEmailVerified Boolean   @default(false) @map("is_email_verified")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(3)

  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]
  addresses          UserAddress[]
  workerProfile      WorkerProfile?
  jobs               Job[]

  @@index([role])
  @@map("users")
}

// =====================================================
// User addresses (Phase 2)
// =====================================================

model UserAddress {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  label      String? // e.g. "Home", "Office"
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String   @map("postal_code")
  country    String   @default("IN")
  lat        Float?
  lng        Float?
  isDefault  Boolean  @default(false) @map("is_default")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs Job[]

  @@index([userId])
  @@map("user_addresses")
}

// =====================================================
// Refresh tokens (hashed at rest)
// =====================================================

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  familyId  String    @map("family_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(3)
  userAgent String?   @map("user_agent")
  ip        String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// =====================================================
// Password reset tokens (single-use)
// =====================================================

model PasswordReset {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_resets")
}

// =====================================================
// Email verification tokens (single-use)
// =====================================================

model EmailVerification {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verifications")
}

// =====================================================
// Worker Profile (Phase 3)
// =====================================================

model WorkerProfile {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid
  headline           String
  bio                String    @db.Text
  yearsExperience    Int       @default(0) @map("years_experience")
  hourlyRate         Int?      @map("hourly_rate") // minor units (e.g. paise/cents)
  city               String
  serviceRadiusKm    Int       @default(10) @map("service_radius_km")
  isVerified         Boolean   @default(false) @map("is_verified")
  verifiedAt         DateTime? @map("verified_at") @db.Timestamptz(3)
  avgRating          Float     @default(0) @map("avg_rating")
  totalJobsCompleted Int       @default(0) @map("total_jobs_completed")
  totalReviews       Int       @default(0) @map("total_reviews")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills    WorkerSkill[]
  portfolio PortfolioItem[]

  @@index([isVerified])
  @@index([city])
  @@index([avgRating])
  @@map("worker_profiles")
}

// =====================================================
// Job taxonomy (Phase 4)
// Category → Subcategory → Skill
// =====================================================

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?
  iconKey     String?  @map("icon_key") // UI hint, e.g. "wrench", "sparkles"
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  subcategories Subcategory[]
  jobs          Job[]

  @@index([isActive, sortOrder])
  @@map("categories")
}

model Subcategory {
  id          String   @id @default(uuid()) @db.Uuid
  categoryId  String   @map("category_id") @db.Uuid
  name        String
  slug        String
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  jobs     Job[]
  skills   Skill[]

  @@unique([categoryId, slug])
  @@index([categoryId, isActive, sortOrder])
  @@map("subcategories")
}

// =====================================================
// Skill catalog (Phase 3 + Phase 4 subcategory link)
// =====================================================

model Skill {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @unique
  slug           String   @unique
  subcategoryId  String?  @map("subcategory_id") @db.Uuid
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  subcategory Subcategory?  @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  workers     WorkerSkill[]

  @@index([subcategoryId])
  @@index([isActive])
  @@map("skills")
}

// =====================================================
// Worker-Skill junction (with level)
// =====================================================

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

model WorkerSkill {
  id              String     @id @default(uuid()) @db.Uuid
  workerProfileId String     @map("worker_profile_id") @db.Uuid
  skillId         String     @map("skill_id") @db.Uuid
  level           SkillLevel @default(INTERMEDIATE)
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)

  worker WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)
  skill  Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([workerProfileId, skillId])
  @@index([skillId])
  @@map("worker_skills")
}

// =====================================================
// Portfolio image metadata
// =====================================================

model PortfolioItem {
  id              String   @id @default(uuid()) @db.Uuid
  workerProfileId String   @map("worker_profile_id") @db.Uuid
  imageUrl        String   @map("image_url")
  caption         String?
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  worker WorkerProfile @relation(fields: [workerProfileId], references: [id], onDelete: Cascade)

  @@index([workerProfileId])
  @@map("portfolio_items")
}

// =====================================================
// Jobs (Phase 5 — Job Posting)
// =====================================================

enum JobStatus {
  DRAFT
  OPEN
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum JobUrgency {
  LOW
  NORMAL
  HIGH
  URGENT
}

model Job {
  id             String    @id @default(uuid()) @db.Uuid
  customerId     String    @map("customer_id") @db.Uuid
  categoryId     String    @map("category_id") @db.Uuid
  subcategoryId  String?   @map("subcategory_id") @db.Uuid
  addressId      String    @map("address_id") @db.Uuid

  title          String    @db.VarChar(120)
  description    String    @db.Text
  budgetMin      Int?      @map("budget_min") // minor units
  budgetMax      Int?      @map("budget_max") // minor units
  currency       String    @default("INR") @db.VarChar(3)
  urgency        JobUrgency @default(NORMAL)
  scheduledFor   DateTime? @map("scheduled_for") @db.Timestamptz(3)
  city           String
  status         JobStatus  @default(OPEN)
  cancelledAt    DateTime?  @map("cancelled_at") @db.Timestamptz(3)
  cancelReason   String?    @map("cancel_reason") @db.VarChar(280)
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz(3)

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)

  customer       User              @relation(fields: [customerId], references: [id], onDelete: Cascade)
  category       Category          @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  subcategory    Subcategory?      @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  address        UserAddress       @relation(fields: [addressId], references: [id], onDelete: Restrict)
  attachments    JobAttachment[]

  @@index([customerId])
  @@index([categoryId])
  @@index([subcategoryId])
  @@index([city])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("jobs")
}

model JobAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  url       String   @db.VarChar(2048)
  caption   String?  @db.VarChar(280)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@map("job_attachments")
}
